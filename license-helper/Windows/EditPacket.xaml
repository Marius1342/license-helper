<Window x:Class="license_helper.Windows.EditPacket"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:license_helper.Windows"
        mc:Ignorable="d"
        Title="EditPacket" Height="450" Width="800">
    <Grid>
        <Label Content="Version" HorizontalAlignment="Left" Margin="151,61,0,0" VerticalAlignment="Top"/>
        <Label Content="Legal Text" HorizontalAlignment="Left" Margin="127,107,0,0" VerticalAlignment="Top"/>
        <Label Content="Name" HorizontalAlignment="Left" Margin="151,38,0,0" VerticalAlignment="Top"/>
        <Label Content="Url" HorizontalAlignment="Left" Margin="151,84,0,0" VerticalAlignment="Top"/>

        <TextBox HorizontalAlignment="Left" Margin="194,42,0,0" TextWrapping="Wrap" x:Name="Name" Text="" VerticalAlignment="Top" Width="557"/>
        <TextBox HorizontalAlignment="Left" Margin="194,65,0,0" TextWrapping="Wrap" x:Name="Version" Text="" VerticalAlignment="Top" Width="557"/>
        <TextBox HorizontalAlignment="Left" Margin="194,88,0,0" TextWrapping="Wrap" x:Name="Url" Text="" VerticalAlignment="Top" Width="557"/>
        <RichTextBox Margin="194,111,49,165" x:Name="LegalText">
            <FlowDocument >
                <Paragraph >
                    <Run Text=""/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>
        <Button Content="Save and Exit" HorizontalAlignment="Center" Margin="0,296,0,0" VerticalAlignment="Top" Click="SaveAndExit"/>
        <Button Content="Remove" HorizontalAlignment="Center" Margin="0,347,0,0" VerticalAlignment="Top" Click="Remove"/>
    </Grid>
</Window>
