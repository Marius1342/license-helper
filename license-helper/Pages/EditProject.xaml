<Page x:Class="license_helper.Pages.EditProject"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:license_helper.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EditProject">

    <Grid Background="WhiteSmoke">
        <Label Content="Name" HorizontalAlignment="Left" Margin="39,41,0,0" VerticalAlignment="Top" Width="87"/>
        <Label Content="Project url" HorizontalAlignment="Left" Margin="39,72,0,0" VerticalAlignment="Top" Width="87"/>
        <Label Content="Extra infos" HorizontalAlignment="Left" Margin="39,103,0,0" VerticalAlignment="Top" Width="87"/>
        <Label Content="Version" HorizontalAlignment="Left" Margin="39,130,0,0" VerticalAlignment="Top" Width="87"/>
        <TextBox HorizontalAlignment="Left" x:Name="nameProject" Margin="131,49,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="328"/>
        <TextBox HorizontalAlignment="Left" x:Name="projectUrl" Margin="131,76,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="328"/>
        <TextBox HorizontalAlignment="Left" x:Name="extraInfos" Margin="131,107,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="328"/>
        <TextBox HorizontalAlignment="Left" x:Name="version" Margin="131,134,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="328"/>
        <Button Content="Save" HorizontalAlignment="Left" Margin="131,174,0,0" VerticalAlignment="Top" Width="328" Click="Button_Click"/>
        <Button Content="Main menue" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="116" Click="Button_Click_1"/>
        <Button Content="Add new packet" HorizontalAlignment="Left" Margin="237,225,0,0" VerticalAlignment="Top" Width="116" Click="addNewPacket"/>
        <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" x:Name="packets" Margin="614,225,10,10" SelectionChanged="packets_SelectionChanged"/>
        <TextBox HorizontalAlignment="Left" x:Name="namePacket" Margin="642,202,0,0" TextWrapping="Wrap" Text="name of packet" VerticalAlignment="Top" Width="120"/>
        <ComboBox HorizontalAlignment="Left" x:Name="templates" Margin="92,320,0,0" VerticalAlignment="Top" Width="405"/>
        <Label Content="Export" HorizontalAlignment="Left" Margin="268,289,0,0" VerticalAlignment="Top" Width="53"/>
        <Button Content="Export" x:Name="export" HorizontalAlignment="Left" Margin="276,348,0,0" VerticalAlignment="Top" Click="Export_Click"/>



    </Grid>
</Page>
