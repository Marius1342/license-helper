<Page x:Class="license_helper.Pages.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:license_helper.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Settings" Background="WhiteSmoke">
    <Grid>
        <Label Content="Db Locations" HorizontalAlignment="Left" Margin="288,116,0,0" VerticalAlignment="Top" Width="79"/>
        <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" x:Name="AllOtherLocations" Margin="210,147,355,194" SelectionChanged="AllOtherLocations_SelectionChanged"/>
        <Label Content="Add new" HorizontalAlignment="Left" Margin="561,116,0,0" VerticalAlignment="Top" Width="58"/>
        <TextBox HorizontalAlignment="Left" x:Name="Location" Margin="530,147,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Button Content="Add" HorizontalAlignment="Left" x:Name="Add" Margin="662,145,0,0" VerticalAlignment="Top" Click="Add_Click"/>
        <Button Content="Save and Back" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Height="51" Width="103" Click="SaveAndBack"/>



    </Grid>
</Page>
