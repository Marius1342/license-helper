<Page x:Class="license_helper.Pages.AddProject"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:license_helper.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddProject">

    <Grid Background="WhiteSmoke">
        <Label Content="Name" HorizontalAlignment="Left" Margin="98,104,0,0" VerticalAlignment="Top" Width="87"/>
        <Label Content="Project url" HorizontalAlignment="Left" Margin="98,135,0,0" VerticalAlignment="Top" Width="87"/>
        <Label Content="Extra infos" HorizontalAlignment="Left" Margin="98,166,0,0" VerticalAlignment="Top" Width="87"/>
        <Label Content="Version" HorizontalAlignment="Left" Margin="98,193,0,0" VerticalAlignment="Top" Width="87"/>
        <TextBox HorizontalAlignment="Left" x:Name="nameProject" Margin="190,112,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="328"/>
        <TextBox HorizontalAlignment="Left" x:Name="projectUrl" Margin="190,139,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="328"/>
        <TextBox HorizontalAlignment="Left" x:Name="extraInfos" Margin="190,170,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="328"/>
        <TextBox HorizontalAlignment="Left" x:Name="version" Margin="190,197,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="328"/>
        <Button Content="Add project" HorizontalAlignment="Left" Margin="190,249,0,0" VerticalAlignment="Top" Width="328" Click="Button_Click"/>
        


    </Grid>
</Page>
